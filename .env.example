# ──────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────
# Password for the local postgres container (dev default is fine locally).
POSTGRES_PASSWORD=voicetuner_dev

# Override the full connection URL if you use an external PostgreSQL server.
# Leave commented out to use the bundled postgres container.
# DATABASE_URL=postgresql://voicetuner:voicetuner_dev@localhost:5432/voicetuner

# ──────────────────────────────────────────────────────────────────────────
# Cloud speech providers.  Copy this file to `.env` and fill in real values.
# NEVER commit `.env`.
#
# FREE-TIER DEMO SETUP: only SARVAM_API_KEY is needed for the headline feature
# (English/Hindi/Telugu TTS + STT). Groq is an optional free STT speed-up.
# ElevenLabs is OPTIONAL and only used for Telugu/Hindi *voice cloning*, which
# requires a PAID ElevenLabs plan — leave it blank for a free demo.
# ──────────────────────────────────────────────────────────────────────────

# Sarvam — Indic TTS (Bulbul) + STT (Saarika) for en/hi/te. PRIMARY, free tier.
# https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Groq — hosted Whisper-large-v3 STT (fast cloud transcription). Optional, free.
# https://console.groq.com/keys
GROQ_API_KEY=

# ElevenLabs — voice cloning for en/hi/te. OPTIONAL, requires a PAID plan
# (free tier returns paid_plan_required). Leave blank for the free demo;
# English/Hindi voice cloning still works locally via Chatterbox.
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Language policy (centralized — see backend/languages.py)
# ──────────────────────────────────────────────────────────────────────────
# Comma-separated allow-list. Do not add codes the speech stack can't serve.
SUPPORTED_LANGUAGES=en,hi,te

# Speech routing: which provider serves each modality.
# Values: local | sarvam | groq | elevenlabs | auto
TTS_PROVIDER=auto          # auto = local for en, Sarvam for hi/te
STT_PROVIDER=auto          # auto = local Whisper for en, Sarvam/Groq for hi/te
VOICE_CLONE_PROVIDER=auto  # auto = local Chatterbox for en/hi; te needs ElevenLabs (paid)
