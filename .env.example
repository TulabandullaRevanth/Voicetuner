# ──────────────────────────────────────────────────────────────────────────
# Local PostgreSQL (runs on the host machine, NOT in Docker)
# ──────────────────────────────────────────────────────────────────────────
# Connection details for your local PostgreSQL installation.
# ./start.sh creates the voicetuner role/database automatically on first run.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_superuser_password
POSTGRES_HOST=host.docker.internal   # Docker backend reaches the host via this hostname
POSTGRES_PORT=5432                   # Change to 5433 if EDB installer used that port

# The DATABASE_URL is built by start.sh from the values above.
# Override here only if your setup differs:
# DATABASE_URL=postgresql://voicetuner:voicetuner_dev@host.docker.internal:5432/voicetuner

# ──────────────────────────────────────────────────────────────────────────
# Cloud speech providers.  Copy this file to `.env` and fill in real values.
# NEVER commit `.env`.
#
# English-only setup: all TTS/STT runs locally. Cloud keys are optional.
# Groq gives faster cloud STT. ElevenLabs enables cloud voice cloning (paid).
# ──────────────────────────────────────────────────────────────────────────

# Sarvam — cloud TTS/STT (optional for English-only deployments).
# https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Groq — hosted Whisper-large-v3 STT (fast cloud transcription). Optional, free.
# https://console.groq.com/keys
GROQ_API_KEY=

# ElevenLabs — cloud voice cloning. OPTIONAL, requires a PAID plan.
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Language policy (centralized — see backend/languages.py)
# ──────────────────────────────────────────────────────────────────────────
# Comma-separated allow-list.
SUPPORTED_LANGUAGES=en

# Speech routing: which provider serves each modality.
# Values: local | sarvam | groq | elevenlabs | auto
TTS_PROVIDER=auto          # auto = local engines for en
STT_PROVIDER=auto          # auto = local Whisper for en
VOICE_CLONE_PROVIDER=auto  # auto = local Chatterbox for en
